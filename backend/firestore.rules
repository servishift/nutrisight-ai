rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.role in ['admin', 'superadmin'];
    }
    
    function isSuperAdmin() {
      return request.auth != null && 
             request.auth.token.role == 'superadmin';
    }
    
    // Audit logs - admins can read and write
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;  // Immutable
    }
    
    // Additives - public read, admin write
    match /additives/{additiveId} {
      allow read: if true;  // Public read for all users
      allow create, update, delete: if isAdmin();
    }
    
    // Analyses - users can write their own, admins can read all
    match /analyses/{analysisId} {
      allow read: if request.auth != null && 
                     (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null && 
                       request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && 
                               (resource.data.userId == request.auth.uid || isAdmin());
    }
    
    // User profiles (optional - for storing additional user data)
    match /users/{userId} {
      allow read: if request.auth != null && 
                     (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && 
                      (request.auth.uid == userId || isAdmin());
    }
    
    // Settings - superadmin only
    match /settings/{settingId} {
      allow read: if isAdmin();
      allow write: if isSuperAdmin();
    }
  }
}
